{
  "suggest.echodocSupport": true,
  "suggest.maxCompleteItemCount": 20,
  "prettier.formatterPriority": -1,
  "coc.preferences.formatOnSaveFiletypes": [
    "typescript",
    "typescriptreact",
    "json",
    "javascriptreact",
    "typescript.tsx",
    "css",
    "markdown"
  ],
  "eslint.filetypes": [
    "javascript",
    "typescript",
    "typescriptreact",
    "javascriptreact",
    "typescript.tsx"
  ],
  "html.enable": true,
  "html.format.enable": true,
  "html.filetypes": [
    "html",
    "htmldjango",
    "handlebars",
    "django"
  ],
  "diagnostic.errorSign": "•",
  "diagnostic.warningSign": "•",
  "diagnostic.infoSign": "•"
}
